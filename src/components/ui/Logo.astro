---
interface Props {
  inverse?: boolean;
}

const { inverse = false } = Astro.props;
---

<span class={`logo ${inverse ? "logo--inverse" : ""}`.trim()}>
  <span class="logo__mark">Logo</span>
  <span class="logo__text">STP</span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: var(--weight-bold);
    letter-spacing: -0.03em;
    color: var(--color-text-strong);
  }

  .logo__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.6rem;
    height: 1.5rem;
    padding-inline: 0.35rem;
    border-radius: 0.375rem;
    background: linear-gradient(
      135deg,
      var(--color-primary-600),
      var(--color-primary-500)
    );
    color: var(--color-neutral-0);
    font-size: 0.45rem;
    line-height: 1;
    letter-spacing: 0;
    font-weight: var(--weight-bold);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.22);
  }

  .logo--inverse {
    color: var(--color-neutral-0);
  }
</style>
