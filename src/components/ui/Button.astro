---
import Icon from "./Icon.astro";
import type { IconName } from "../../data/landing";

interface Props {
  label: string;
  variant?: "primary" | "secondary";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit" | "reset";
  icon?: IconName;
  iconPosition?: "left" | "right";
  iconStrokeWidth?: string;
  fullWidth?: boolean;
}

const {
  label,
  variant = "primary",
  size = "md",
  href,
  type = "button",
  icon,
  iconPosition = "right",
  iconStrokeWidth,
  fullWidth = false,
} = Astro.props;

const className =
  `button button--${variant} button--${size} ${fullWidth ? "button--full" : ""}`.trim();
const iconName = icon as IconName;
const iconSize = size === "lg" ? "22" : "18";
---

{
  href ? (
    <a class={className} href={href}>
      {iconName && iconPosition === "left" ? (
        <Icon
          name={iconName}
          size={iconSize}
          strokeWidth={iconStrokeWidth || "2"}
        />
      ) : null}
      <span>{label}</span>
      {iconName && iconPosition === "right" ? (
        <Icon
          name={iconName}
          size={iconSize}
          strokeWidth={iconStrokeWidth || "2"}
        />
      ) : null}
    </a>
  ) : (
    <button class={className} type={type}>
      {iconName && iconPosition === "left" ? (
        <Icon
          name={iconName}
          size={iconSize}
          strokeWidth={iconStrokeWidth || "2"}
        />
      ) : null}
      <span>{label}</span>
      {iconName && iconPosition === "right" ? (
        <Icon
          name={iconName}
          size={iconSize}
          strokeWidth={iconStrokeWidth || "2"}
        />
      ) : null}
    </button>
  )
}

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    font-weight: var(--weight-semibold);
    line-height: 1;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
  }

  .button:hover {
    transform: translateY(-0.5px);
  }

  .button:active {
    transform: translateY(0);
  }

  .button--primary {
    background: var(--color-primary-600);
    color: var(--color-neutral-0);
    box-shadow: 0 10px 24px rgba(29, 78, 216, 0.22);
  }

  .button--primary:hover {
    background: var(--color-primary-700);
    box-shadow: 0 18px 44px rgba(29, 78, 216, 0.3);
  }

  .button--secondary {
    background: rgba(255, 255, 255, 0.96);
    color: var(--color-text-strong);
    border-color: rgba(17, 24, 39, 0.08);
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04);
  }

  .button--secondary:hover {
    border-color: rgba(37, 99, 235, 0.18);
    box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
  }

  .button--sm {
    min-height: 2.5rem;
    padding-inline: 0.875rem;
    font-size: 0.8125rem;
  }

  .button--md {
    min-height: 2.875rem;
    padding-inline: 1.375rem;
    font-size: 0.875rem;
  }

  .button--lg {
    min-height: 3.25rem;
    padding-inline: 1.5rem;
    font-size: 0.875rem;
  }

  .button--full {
    width: 100%;
  }
</style>
