---
interface Props {
  class?: string;
  padding?: "md" | "lg";
}

const { class: className = "", padding = "lg" } = Astro.props;
---

<article class={`card card--${padding} ${className}`.trim()}>
  <slot />
</article>

<style>
  .card {
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-md);
  }

  .card--md {
    padding: 1.25rem;
  }

  .card--lg {
    padding: 1.75rem;
  }
</style>
