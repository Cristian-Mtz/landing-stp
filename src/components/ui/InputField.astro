---
import Icon from "./Icon.astro";
import type { IconName } from "../../data/landing";

interface Props {
  label: string;
  name: string;
  type?: "text" | "email" | "tel";
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  icon?: IconName;
  error?: string;
}

const {
  label,
  name,
  type = "text",
  placeholder = "",
  required = false,
  autocomplete,
  icon,
  error = `Ingresa un valor válido en ${label.toLowerCase().replace("*", "").trim()}.`,
} = Astro.props;

const messageId = `${name}-message`;
---

<div class="field" data-field data-default-error={error}>
  <label class="field__label" for={name}>
    {label}
    {required && <span> *</span>}
  </label>
  <div class={`field__control ${icon ? "field__control--icon" : ""}`.trim()}>
    {
      icon && (
        <span class="field__icon" aria-hidden="true">
          <Icon name={icon} size="18" strokeWidth="1.9" />
        </span>
      )
    }
    <input
      id={name}
      name={name}
      type={type}
      placeholder={placeholder}
      required={required}
      autocomplete={autocomplete}
      aria-describedby={messageId}
    />
  </div>
  <p class="field__message" id={messageId} hidden></p>
</div>

<style>
  .field {
    display: grid;
    gap: 0.5rem;
  }

  .field__label {
    font-size: 0.75rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text-strong);
    letter-spacing: -0.01em;
  }

  .field__control {
    position: relative;
  }

  .field__icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-neutral-400);
  }

  .field input {
    width: 100%;
    height: 2.75rem;
    border: 1px solid rgba(17, 24, 39, 0.08);
    border-radius: var(--radius-lg);
    background: var(--color-neutral-0);
    padding-inline: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-strong);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  .field__control--icon input {
    padding-left: 2.75rem;
  }

  .field input::placeholder {
    color: var(--color-neutral-400);
  }

  .field input:hover {
    border-color: rgba(37, 99, 235, 0.16);
  }

  .field[data-state="error"] input {
    border-color: color-mix(in srgb, var(--color-error) 60%, white);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-error) 12%, white);
  }

  .field[data-state="success"] input {
    border-color: color-mix(in srgb, var(--color-success) 70%, white);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-success) 12%, white);
  }

  .field__message {
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--color-error);
  }

  .field[data-state="success"] .field__message {
    color: var(--color-success);
  }
</style>
