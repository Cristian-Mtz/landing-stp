---
import type { NavLink } from "../../data/landing";
import Button from "../ui/Button.astro";
import Icon from "../ui/Icon.astro";
import Container from "../ui/Container.astro";
import Logo from "../ui/Logo.astro";

interface Props {
  links: NavLink[];
  ctaLabel: string;
  ctaHref: string;
}

const { links, ctaLabel, ctaHref } = Astro.props;
---

<header class="site-header">
  <Container>
    <div class="site-header__inner">
      <a href="#inicio" aria-label="Ir al inicio">
        <Logo />
      </a>

      <nav class="site-header__nav" aria-label="Navegación principal">
        <ul>
          {
            links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="site-header__cta">
        <Button label={ctaLabel} href={ctaHref} size="sm" />
      </div>

      <details class="site-header__mobile">
        <summary aria-label="Abrir menú">
          <Icon name="menu" size="22" />
        </summary>
        <nav aria-label="Navegación móvil">
          <ul>
            {
              links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
            <li>
              <a class="site-header__mobile-cta" href={ctaHref}>{ctaLabel}</a>
            </li>
          </ul>
        </nav>
      </details>
    </div>
  </Container>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(17, 24, 39, 0.06);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    min-height: 3.75rem;
    padding-block: 0.35rem;
  }

  .site-header__nav ul {
    display: flex;
    justify-content: center;
    gap: 1.75rem;
    font-size: 0.75rem;
    font-weight: var(--weight-medium);
    color: var(--color-neutral-600);
  }

  .site-header__nav a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
  }

  .site-header__nav a:hover {
    color: var(--color-text-strong);
  }

  .site-header__mobile {
    display: none;
    position: relative;
  }

  .site-header__mobile summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--shadow-sm);
    list-style: none;
  }

  .site-header__mobile summary::-webkit-details-marker {
    display: none;
  }

  .site-header__mobile nav {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    min-width: 13rem;
    padding: 0.875rem;
    border-radius: var(--radius-2xl);
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
  }

  .site-header__mobile ul {
    display: grid;
    gap: 0.875rem;
  }

  .site-header__mobile a {
    display: block;
    padding: 0.3rem 0;
  }

  .site-header__mobile-cta {
    padding: 0.75rem 0.875rem !important;
    border-radius: var(--radius-lg);
    background: var(--color-primary-600);
    color: var(--color-neutral-0);
    text-align: center;
  }

  @media (max-width: 1023px) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .site-header__nav,
    .site-header__cta {
      display: none;
    }

    .site-header__mobile {
      display: block;
      justify-self: end;
    }
  }
</style>
