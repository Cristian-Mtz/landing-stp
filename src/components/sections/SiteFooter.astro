---
import type { FooterColumn, NavLink, SocialLink } from "../../data/landing";
import { footerContact } from "../../data/landing";
import Container from "../ui/Container.astro";
import Icon from "../ui/Icon.astro";
import Logo from "../ui/Logo.astro";

interface Props {
  columns: FooterColumn[];
  legalLinks: NavLink[];
  socialLinks: SocialLink[];
}

const { columns, legalLinks, socialLinks } = Astro.props;
const isExternalLink = (href: string) =>
  href.startsWith("http://") || href.startsWith("https://");
---

<footer class="site-footer">
  <Container>
    <div class="site-footer__inner">
      <div class="site-footer__top">
        <div class="site-footer__brand">
          <a href="#inicio" aria-label="Ir al inicio">
            <Logo inverse={true} />
          </a>
          <p>{footerContact.description}</p>
          <ul class="site-footer__contact">
            <li>
              <Icon name="map-pin" size="14" strokeWidth="1.9" />
              <span>{footerContact.address}</span>
            </li>
            <li>
              <Icon name="phone" size="14" strokeWidth="1.9" />
              <a href={`tel:${footerContact.phone}`}>{footerContact.phone}</a>
            </li>
            <li>
              <Icon name="mail" size="14" strokeWidth="1.9" />
              <a href={`mailto:${footerContact.email}`}>{footerContact.email}</a
              >
            </li>
          </ul>
        </div>

        {
          columns.map((column) => (
            <div class="site-footer__column">
              <h2>{column.title}</h2>
              <ul>
                {column.links.map((link) => (
                  <li>
                    <a href={link.href}>{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="site-footer__bottom">
        <div class="site-footer__legal">
          {legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>

        <div class="site-footer__social">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                aria-label={link.label}
                target={isExternalLink(link.href) ? "_blank" : undefined}
                rel={isExternalLink(link.href) ? "noreferrer" : undefined}
              >
                <Icon name={link.icon} size="12" strokeWidth="1.9" />
              </a>
            ))
          }
        </div>
      </div>

      <div class="site-footer__note">
        <p>{footerContact.copyright}</p>
        <p>{footerContact.regulation}</p>
      </div>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    padding-block: 1.5rem 1rem;
    background: #121b2d;
    color: rgba(255, 255, 255, 0.68);
  }

  .site-footer__inner {
    display: grid;
    gap: 1.75rem;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(2, minmax(10rem, 1fr));
    gap: 1.5rem;
  }

  .site-footer__brand p {
    max-width: 16rem;
    margin-top: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .site-footer__contact {
    display: grid;
    gap: 0.625rem;
  }

  .site-footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .site-footer__column h2 {
    margin-bottom: 0.875rem;
    font-size: 0.875rem;
    font-weight: var(--weight-semibold);
    color: var(--color-neutral-0);
  }

  .site-footer__column ul {
    display: grid;
    gap: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .site-footer__column a:hover,
  .site-footer__contact a:hover,
  .site-footer__legal a:hover {
    color: var(--color-neutral-0);
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .site-footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .site-footer__social {
    display: flex;
    gap: 0.375rem;
  }

  .site-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-neutral-0);
  }

  .site-footer__social a:hover {
    background: rgba(37, 99, 235, 0.18);
  }

  .site-footer__note {
    display: grid;
    gap: 0.375rem;
    text-align: center;
    font-size: 0.75rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.44);
  }

  @media (max-width: 1023px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
