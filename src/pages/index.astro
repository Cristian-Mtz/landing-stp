---
import BenefitsSection from "../components/sections/BenefitsSection.astro";
import CompatibilitySection from "../components/sections/CompatibilitySection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import PlatformSection from "../components/sections/PlatformSection.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
import SiteHeader from "../components/sections/SiteHeader.astro";
import {
  footerColumns,
  footerLegalLinks,
  formBenefits,
  navLinks,
  siteMeta,
  socialLinks,
} from "../data/landing";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <SiteHeader
    links={navLinks}
    ctaLabel="Solicitar información"
    ctaHref="#contacto"
  />
  <main id="main-content">
    <HeroSection />
    <BenefitsSection />
    <PlatformSection />
    <CompatibilitySection />
    <ContactSection benefits={formBenefits} />
  </main>
  <SiteFooter
    columns={footerColumns}
    legalLinks={footerLegalLinks}
    socialLinks={socialLinks}
  />
</BaseLayout>
